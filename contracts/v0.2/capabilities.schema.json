{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ulpi.io/handoff/contracts/v0.2/capabilities.schema.json",
  "title": "Handoff v0.2 capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "driverVersion", "bundleVersion", "bundleDigest", "roles", "providers"],
  "properties": {
    "schemaVersion": { "const": "handoff.capabilities.v0.2" },
    "driverVersion": { "const": "0.3.0" },
    "bundleVersion": { "const": "0.3.0" },
    "bundleDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "roles": { "const": ["build", "phase", "review", "verify"] },
    "providers": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/provider" }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "pipeline"],
      "properties": {
        "id": { "enum": ["codex", "grok", "kiro", "claude", "opencode", "cursor"] },
        "pipeline": {
          "type": "object",
          "additionalProperties": false,
          "required": ["safe", "roles", "executable", "preflight", "policies"],
          "properties": {
            "safe": { "const": true },
            "roles": {
              "type": "array",
              "minItems": 1,
              "maxItems": 4,
              "uniqueItems": true,
              "items": { "enum": ["build", "phase", "review", "verify"] }
            },
            "executable": { "type": ["string", "null"] },
            "preflight": {
              "type": "object",
              "additionalProperties": false,
              "required": ["installed", "ok", "version", "reason"],
              "properties": {
                "installed": { "type": "boolean" },
                "ok": { "type": "boolean" },
                "version": { "type": ["string", "null"] },
                "reason": { "type": ["string", "null"] }
              }
            },
            "policies": {
              "type": "object",
              "additionalProperties": false,
              "minProperties": 1,
              "properties": {
                "build": { "$ref": "#/$defs/policy" },
                "phase": { "$ref": "#/$defs/policy" },
                "review": { "$ref": "#/$defs/policy" },
                "verify": { "$ref": "#/$defs/policy" }
              }
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enforcement"],
      "properties": {
        "enforcement": { "type": "string" },
        "filesystem": { "type": "string" },
        "approvals": { "type": "string" },
        "ephemeral": { "type": "boolean" },
        "userConfiguration": { "type": "string" },
        "managedConfiguration": { "type": "string" },
        "projectRules": { "type": "string" },
        "nativeAgentsLoading": { "type": "string" },
        "execPolicyRules": { "type": "string" },
        "coordinatorApprovalRequired": { "type": "boolean" },
        "sandboxProfile": { "type": "string" },
        "permissionMode": { "type": "string" },
        "webSearch": { "type": "boolean" },
        "subagents": { "type": "boolean" },
        "memory": { "type": "boolean" },
        "maxTurns": { "type": "integer", "minimum": 1 },
        "network": { "type": "string" },
        "readScope": { "type": "string" },
        "writableLocations": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "nativeFilesystemIsolation": { "type": "boolean" },
        "nativeBashSandbox": { "type": "boolean" },
        "fileToolConfinement": { "type": "string" },
        "toolAllowlist": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "structuredResult": { "type": "string" },
        "providerState": { "type": "string" },
        "applyMode": { "type": "string" }
      }
    }
  }
}
