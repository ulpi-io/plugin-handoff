{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ulpi.io/handoff/contracts/v0.2/result.schema.json",
  "title": "Handoff v0.2 normalized result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "driverVersion", "bundleVersion", "bundleDigest", "provider", "role", "policy", "requestHash", "status", "exit", "output", "git", "timing", "usage", "diagnostics"],
  "properties": {
    "schemaVersion": { "const": "handoff.result.v0.2" },
    "driverVersion": { "const": "0.3.0" },
    "bundleVersion": { "const": "0.3.0" },
    "bundleDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] }
      }
    },
    "role": { "type": ["string", "null"], "enum": ["build", "phase", "review", "verify", null] },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enforcement", "sameUidThreatModel"],
      "properties": {
        "enforcement": { "type": "string" },
        "sameUidThreatModel": { "type": "string" },
        "filesystem": { "type": "string" },
        "approvals": { "type": "string" },
        "ephemeral": { "type": "boolean" },
        "userConfiguration": { "type": "string" },
        "managedConfiguration": { "type": "string" },
        "projectRules": { "type": "string" },
        "nativeAgentsLoading": { "type": "string" },
        "execPolicyRules": { "type": "string" },
        "coordinatorApprovalRequired": { "type": "boolean" },
        "coordinatorApprovalId": { "type": "string" },
        "coordinatorApprovalIssuer": { "type": "string" },
        "coordinatorApprovalScope": { "type": "string" },
        "coordinatorApprovalSubjectHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "agentsRulesDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "injectedAgentsRules": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "agentsRulesCompleteness": { "type": "string" },
        "sandboxProfile": { "type": "string" },
        "permissionMode": { "type": "string" },
        "webSearch": { "type": "boolean" },
        "subagents": { "type": "boolean" },
        "memory": { "type": "boolean" },
        "maxTurns": { "type": "integer", "minimum": 1 },
        "network": { "type": "string" },
        "readScope": { "type": "string" },
        "writableLocations": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "nativeFilesystemIsolation": { "type": "boolean" },
        "nativeBashSandbox": { "type": "boolean" },
        "fileToolConfinement": { "type": "string" },
        "toolAllowlist": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "structuredResult": { "type": "string" },
        "providerState": { "type": "string" },
        "applyMode": { "type": "string" }
      }
    },
    "requestHash": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" },
    "status": { "enum": ["succeeded", "blocked", "failed", "timed_out", "cancelled", "rejected", "not_run"] },
    "exit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["driver", "provider", "signal", "timedOut", "cancelled"],
      "properties": {
        "driver": { "type": "integer" },
        "provider": { "type": ["integer", "null"] },
        "signal": { "type": ["string", "null"] },
        "timedOut": { "type": "boolean" },
        "cancelled": { "type": "boolean" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "evidence", "findings"],
      "properties": {
        "summary": { "type": ["string", "null"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["before", "after", "changed", "changedFiles"],
      "properties": {
        "before": { "anyOf": [{ "$ref": "#/$defs/fingerprint" }, { "type": "null" }] },
        "after": { "anyOf": [{ "$ref": "#/$defs/fingerprint" }, { "type": "null" }] },
        "changed": { "type": "boolean" },
        "changedFiles": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startedAt", "finishedAt", "durationMs"],
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "finishedAt": { "type": "string", "format": "date-time" },
        "durationMs": { "type": "integer", "minimum": 0 }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "inputTokens", "outputTokens", "totalTokens"],
      "properties": {
        "source": { "enum": ["provider-output", "provider-envelope", "not-reported", "not-observed"] },
        "inputTokens": { "type": ["integer", "null"], "minimum": 0 },
        "outputTokens": { "type": ["integer", "null"], "minimum": 0 },
        "totalTokens": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message", "providerStderr", "providerStdout", "truncated", "redactionCount"],
      "properties": {
        "message": { "type": ["string", "null"] },
        "providerStderr": { "type": "string" },
        "providerStdout": { "type": "string" },
        "truncated": { "type": "boolean" },
        "redactionCount": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary"],
      "properties": {
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "summary"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "severity": { "enum": ["blocker", "high", "medium", "low", "nit"] },
        "summary": { "type": "string" }
      }
    },
    "fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "algorithm", "digest", "head", "entryCount", "changeCounts", "changes"],
      "properties": {
        "schemaVersion": { "const": "handoff.git-fingerprint.v0.2" },
        "algorithm": { "const": "sha256" },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "head": { "type": ["string", "null"] },
        "entryCount": { "type": "integer", "minimum": 0 },
        "changeCounts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tracked", "staged", "unstaged", "untracked", "deleted", "renamed", "symlink"],
          "properties": {
            "tracked": { "type": "integer", "minimum": 0 },
            "staged": { "type": "integer", "minimum": 0 },
            "unstaged": { "type": "integer", "minimum": 0 },
            "untracked": { "type": "integer", "minimum": 0 },
            "deleted": { "type": "integer", "minimum": 0 },
            "renamed": { "type": "integer", "minimum": 0 },
            "symlink": { "type": "integer", "minimum": 0 }
          }
        },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "originalPath", "tracked", "untracked", "staged", "unstaged", "deleted", "renamed", "symlink", "indexStatus", "worktreeStatus"],
            "properties": {
              "path": { "type": "string" },
              "originalPath": { "type": ["string", "null"] },
              "tracked": { "type": "boolean" },
              "untracked": { "type": "boolean" },
              "staged": { "type": "boolean" },
              "unstaged": { "type": "boolean" },
              "deleted": { "type": "boolean" },
              "renamed": { "type": "boolean" },
              "symlink": { "type": "boolean" },
              "indexStatus": { "type": "string" },
              "worktreeStatus": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
